# ============================================================
# CodeLens — Environment Variables
# Copy this file to .env and adjust values for your setup.
# ============================================================

# --- Database ---
# SQLite database path (relative to project root or absolute)
DATABASE_URL=file:./db/custom.db

# --- CodeLens CLI ---
# Path to the Python 3 interpreter that has tree-sitter installed.
# If you use a virtualenv, point this to the venv's python3 binary.
# REQUIRED — the server will not start without this.
# Default: python3 (uses system Python if tree-sitter is installed globally)
CODELENS_PYTHON=python3

# Path to the main CodeLens CLI script (codelens.py).
# Relative paths are resolved from the project root.
# REQUIRED — the server will not start without this.
CODELENS_SCRIPT=./skills/codelens/scripts/codelens.py

# --- Workspace Validation ---
# When set to "true", workspace paths passed to scan/init commands
# are validated to ensure they are absolute paths pointing to an
# existing directory. Invalid paths are rejected with an error.
# Default: true
CODELENS_VALIDATE_WORKSPACE=true

# --- WebSocket Server ---
# Port for the CodeLens WebSocket server (socket.io).
# Default: 3030
CODELENS_WS_PORT=3030

# --- CORS ---
# Allowed origin(s) for WebSocket and API requests.
# Use comma-separated values for multiple origins, or "*" for development.
# Default: *
CORS_ORIGIN=*
