# ============================================================
# CodeLens Neural Workspace — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in the values.
#
# REQUIRED: Both CODELENS_PYTHON and CODELENS_SCRIPT must be set
# for the CLI integration to work. Without them, the API will
# start in "degraded" mode and CLI commands will return errors.
# ============================================================

# Path to Python 3 interpreter with tree-sitter installed
# Example: /home/you/.venv/bin/python3
CODELENS_PYTHON=

# Path to the CodeLens CLI script (codelens.py)
# Example: ./skills/codelens/scripts/codelens.py
CODELENS_SCRIPT=

# Optional: Node environment (development | production)
# NODE_ENV=development

# Optional: Port for the Next.js dev server (default: 3000)
# PORT=3000

# Optional: Port for the WebSocket server (default: 3030)
# WS_PORT=3030
